[Unit]
Description=Law Assistant Frontend
After=network.target

[Service]
Type=simple
User=__SERVICE_USER__
WorkingDirectory=__APP_DIR__/frontend
ExecStart=/usr/bin/env bash -lc 'npm run dev -- --host 0.0.0.0 --port 5173'
Restart=always
RestartSec=3
Environment=NODE_ENV=development

[Install]
WantedBy=multi-user.target
